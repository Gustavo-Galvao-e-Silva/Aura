# ============================================================================
# ALEMBIC MIGRATION CONFIGURATION
# ============================================================================
# This file is ONLY for running database migrations with Alembic
# Copy this file to .env.migration and fill in your values
#
# WHY A SEPARATE FILE?
# - FastAPI uses port 6543 (transaction pooler) for efficient async queries
# - Alembic needs port 5432 (direct connection) for stable schema changes
# - Using the pooler for migrations can cause "connection already in use" errors

# ============================================================================
# DATABASE URL - DIRECT CONNECTION (Port 5432)
# ============================================================================
# Get this from: Supabase Dashboard → Settings → Database → "Connection string"
#
# Steps:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Click "Connect" button (top right) OR Settings → Database
# 4. Find "Connection string" section
# 5. Click the "Session" tab (port 5432) - THIS ONE FOR MIGRATIONS
# 6. Copy the full connection string
# 7. Replace [YOUR-PASSWORD] with your actual database password

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Example (DO NOT USE THIS - it won't work, just shows the format):
# DATABASE_URL=postgresql://postgres.cvwxyzabcdefghij:MySecurePass123@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# ============================================================================
# NOTICE THE DIFFERENCE:
# ============================================================================
# .env (FastAPI):       ...pooler.supabase.com:6543/postgres  ← Transaction pooler
# .env.migration (This): ...pooler.supabase.com:5432/postgres  ← Direct connection
#                                            ^^^^
#                                    Only difference is the port!

# ============================================================================
# HOW TO USE THIS FILE
# ============================================================================
# When running Alembic commands, load this file instead of .env:
#
# Linux/Mac:
#   env $(cat .env.migration | xargs) alembic upgrade head
#   env $(cat .env.migration | xargs) alembic revision --autogenerate -m "description"
#   env $(cat .env.migration | xargs) alembic current
#   env $(cat .env.migration | xargs) alembic history
#
# Windows (PowerShell):
#   Get-Content .env.migration | ForEach-Object {
#       $key, $value = $_ -split '=', 2
#       [Environment]::SetEnvironmentVariable($key, $value, 'Process')
#   }
#   alembic upgrade head
#
# Or use the provided script:
#   chmod +x scripts/run-migration.sh
#   ./scripts/run-migration.sh upgrade head

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# If you get "password authentication failed":
#   → Go to Supabase Settings → Database → Reset database password
#   → Update both .env and .env.migration with new password
#
# If you get "could not connect to server":
#   → Check that your Supabase project is "Healthy" in dashboard
#   → Verify the connection string is exactly as shown in Supabase
#
# If you get "relation does not exist" after migration:
#   → Make sure you ran: alembic upgrade head
#   → Check Supabase Table Editor to see if tables were created
#
# If you get "type 'vector' does not exist":
#   → Enable pgvector extension: Database → Extensions → search "vector" → Enable
