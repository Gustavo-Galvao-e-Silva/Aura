# ============================================================================
# Revellio Backend - Git Ignore
# ============================================================================

# ============================================================================
# Environment Variables (NEVER commit secrets!)
# ============================================================================
.env
.env.local
.env.*.local
.env.migration

# But DO commit the templates
!.env.example
!.env.migration.example

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Virtual Environments
# ============================================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ============================================================================
# IDEs
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Testing
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ============================================================================
# Alembic
# ============================================================================
# Don't ignore migrations directory, but ignore __pycache__
alembic/versions/__pycache__/

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# Cache Files
# ============================================================================
sentiment_browser_cache.json
fx_cache.json
*.cache

# ============================================================================
# Database
# ============================================================================
*.db
*.sqlite
*.sqlite3

# ============================================================================
# Docker
# ============================================================================
# Keep docker-compose.yml but ignore local overrides
docker-compose.override.yml

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
tmp/
temp/
