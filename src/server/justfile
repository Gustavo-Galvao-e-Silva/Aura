# Revellio Development Commands

# ============================================================================
# DOCKER MODE (Full Stack - from repository root)
# ============================================================================

# Start full stack (backend + frontend + db) in Docker
stack-up:
	cd ../.. && docker compose up -d

# Stop full stack
stack-down:
	cd ../.. && docker compose down

# Rebuild and restart full stack
stack-restart:
	cd ../.. && docker compose down && docker compose up -d --build

# View logs from all services
stack-logs:
	cd ../.. && docker compose logs -f

# View logs from backend only
backend-logs:
	cd ../.. && docker compose logs -f backend

# View logs from frontend only
frontend-logs:
	cd ../.. && docker compose logs -f frontend

# Wipe everything (including volumes)
stack-wipe:
	cd ../.. && docker compose down -v

# ============================================================================
# NATIVE MODE (Local Development - existing commands)
# ============================================================================

# Start the database and adminer (native mode)
up:
	docker compose up -d

# Stop and wipe the database (useful for schema changes)
wipe:
	docker compose down -v

# Start the FastAPI server
dev:
	PYTHONPATH=. uvicorn my_fastapi_app.app.main:app --reload

# Enter the Postgres Shell inside Docker
db:
	docker exec -it server-db-1 psql -U postgres

# Test the Vision Agent with an image
# Usage: just upload <filename>
upload file:
	curl -X POST "http://localhost:8000/upload-invoice" \
	     -H "accept: application/json" \
	     -H "Content-Type: multipart/form-data" \
	     -F "file=@{{file}}"

# View the status of all current liabilities
status:
	curl -s http://localhost:8000/status | jq .

# Install dependencies (production)
pip:
	pip install .

# Install dependencies with dev tools (for local development)
pip-dev:
	pip install -e ".[dev]"

# ============================================================================
# DATABASE MIGRATIONS (Alembic)
# ============================================================================

# Create a new migration (autogenerate from model changes)
# Usage: just migrate "add user email column"
migrate message:
	PYTHONPATH=. alembic revision --autogenerate -m "{{message}}"

# Apply all pending migrations
upgrade:
	PYTHONPATH=. alembic upgrade head

# Rollback one migration
downgrade:
	PYTHONPATH=. alembic downgrade -1

# Show current migration version
migration-current:
	PYTHONPATH=. alembic current

# Show migration history
migration-history:
	PYTHONPATH=. alembic history --verbose

# Rollback to specific revision
# Usage: just migration-goto abc123
migration-goto revision:
	PYTHONPATH=. alembic downgrade {{revision}}

thanks:
	echo thanks nando
