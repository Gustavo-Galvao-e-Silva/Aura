# ============================================================================
# REVELLIO BACKEND CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to git! (it should be in .gitignore)

# ============================================================================
# DATABASE CONFIGURATION - SUPABASE (Production/Team)
# ============================================================================
# Get these from: Supabase Dashboard → Settings → Database → "Connection string"
#
# IMPORTANT: Use the TRANSACTION POOLER (port 6543) for FastAPI runtime!
# This handles async queries efficiently and prevents "too many connections" errors.
#
# Steps to get your Supabase connection string:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Click "Connect" button (top right) OR Settings → Database
# 4. Find "Connection string" section
# 5. Click the "Transaction" tab (port 6543) - THIS ONE FOR FASTAPI
# 6. Copy the full connection string
# 7. Replace [YOUR-PASSWORD] with your actual database password
#    (If you forgot your password, click "Reset database password")

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Example (DO NOT USE THIS - it won't work, just shows the format):
# DATABASE_URL=postgresql://postgres.cvwxyzabcdefghij:MySecurePass123@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ============================================================================
# DATABASE CONFIGURATION - LOCAL (Alternative, for offline development)
# ============================================================================
# If you want to use local PostgreSQL instead of Supabase:
# 1. Uncomment the lines below
# 2. Comment out the DATABASE_URL above
# 3. Run: docker-compose up -d postgres

# DATABASE_URL=postgresql://postgres:example@localhost:5432/postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=example
# POSTGRES_DB=postgres

# ============================================================================
# API KEYS - AI/ML SERVICES
# ============================================================================

# Google Gemini API Key (REQUIRED)
# Used for: Market synthesis, orchestrator decisions
# Get it from: https://makersuite.google.com/app/apikey
# Free tier: 60 requests/minute
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Browser Use API Key (REQUIRED)
# Used for: Sentiment research (political/fiscal news analysis)
# Get it from: https://browseruse.com (sign up for API access)
# Free tier: 20 requests/day (we cache results for 90 minutes)
BROWSER_USE_API_KEY=your_browser_use_api_key_here

# ============================================================================
# API KEYS - FINANCIAL DATA SOURCES
# ============================================================================

# FRED API Key (REQUIRED)
# Used for: US Fed Funds rate, inflation data, yield curve
# Get it from: https://fred.stlouisfed.org/docs/api/api_key.html
# Completely free, no rate limits
FRED_API_KEY=your_fred_api_key_here

# Tavily API Key (REQUIRED)
# Used for: News aggregation (BRL market sentiment)
# Get it from: https://tavily.com
# Free tier: 1000 searches/month
TAVILY_API_KEY=your_tavily_api_key_here

# Wise API Key (OPTIONAL)
# Used for: FX rate comparison (alternative to Crebit)
# Get it from: https://wise.com/help/articles/2958108/wise-api
# Only needed if you want Wise as a payment route option
WISE_API_KEY=your_wise_api_key_here

# ============================================================================
# BLOCKCHAIN CONFIGURATION - STELLAR TESTNET
# ============================================================================

# Stellar Secret Key (REQUIRED for Trust Engine)
# This is your testnet account that signs blockchain transactions
#
# To create a new testnet account:
# 1. Go to: https://laboratory.stellar.org/#account-creator?network=test
# 2. Click "Generate keypair"
# 3. Copy the SECRET KEY (starts with 'S') - this goes below
# 4. Copy the PUBLIC KEY (starts with 'G') - save this for reference
# 5. Click "Fund account with Friendbot" to get free testnet XLM
#
# IMPORTANT: This is a testnet key only (no real money).
# For production, use a hardware wallet or key management service.
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar Mock-BRZ Issuer (OPTIONAL - only for Phase 2 stablecoin sandbox)
# This is the public key of the account that issues Mock-BRZ tokens
# Leave empty for now - you'll set this up during Phase 2
STELLAR_MOCK_BRZ_ISSUER=

# Stellar Hot Wallet (OPTIONAL - only for Phase 2 stablecoin sandbox)
# This is your default wallet for custody of stablecoins
# Leave empty for now - you'll set this up during Phase 2
STELLAR_HOT_WALLET=

# ============================================================================
# EMAIL CONFIGURATION - SMTP (OPTIONAL)
# ============================================================================
# Used for: Sending payment receipts, rate alerts
# If not configured, emails will be logged instead of sent (non-fatal)

# Gmail Example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password  # NOT your regular password! Use App Password
FROM_EMAIL=your_email@gmail.com

# To set up Gmail App Password:
# 1. Enable 2FA on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail"
# 4. Use that 16-character password above

# SendGrid Example (alternative):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# FROM_EMAIL=noreply@revellio.com

# ============================================================================
# STABLECOIN CONFIGURATION - STRIPE & CIRCLE (Phase 2 Only)
# ============================================================================
# Leave these empty for now - you'll set these up during Phase 2

# Stripe Configuration (for BRL deposits via PIX)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Circle Configuration (for USDC → USD fiat off-ramp)
# Get from: https://developers.circle.com/docs/sandbox
CIRCLE_API_KEY=
CIRCLE_USDC_HOT_WALLET=

# ============================================================================
# APPLICATION SETTINGS (Defaults - usually no need to change)
# ============================================================================

# Cache expiry for FX market data (in minutes)
CACHE_EXPIRY_MINUTES=120

# HTTP client timeout for external API calls (in seconds)
HTTP_CLIENT_TIMEOUT=20.0

# Stellar transaction timeout (in seconds)
STELLAR_TRANSACTION_TIMEOUT=30

# Stellar base fee (in stroops, 1 XLM = 10,000,000 stroops)
STELLAR_BASE_FEE=100

# Default account balances for new users (Phase 2)
DEFAULT_BRL_BALANCE=50000.0
DEFAULT_USD_BALANCE=0.0

# Market monitor background task interval (in seconds)
MARKET_MONITOR_INTERVAL_SECONDS=60

# CORS allowed origins (add your frontend URL here)
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================================
# QUICK SETUP CHECKLIST
# ============================================================================
# Before running the app, make sure you have:
#
# [x] 1. Created Supabase project and got DATABASE_URL (port 6543)
# [x] 2. Enabled pgvector extension in Supabase (Database → Extensions → vector)
# [x] 3. Got GOOGLE_API_KEY from Google AI Studio
# [x] 4. Got BROWSER_USE_API_KEY from browseruse.com
# [x] 5. Got FRED_API_KEY from FRED website (free)
# [x] 6. Got TAVILY_API_KEY from Tavily (free tier)
# [x] 7. Generated STELLAR_SECRET_KEY from Stellar Laboratory
# [x] 8. Copied this file to .env and filled in actual values
# [x] 9. Created .env.migration (see .env.migration.example)
# [x] 10. Ran: alembic upgrade head (to create tables in Supabase)
#
# Then run: uvicorn my_fastapi_app.app.main:app --reload
# And visit: http://localhost:8000/docs
#
# For full setup instructions, see: SUPABASE_MIGRATION.md
