# Database Configuration
# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=revellio

# Database connection URL (used by application)
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/revellio

# API Keys - AI/ML Services
GOOGLE_API_KEY=your_google_gemini_api_key_here
BROWSER_USE_API_KEY=your_browser_use_api_key_here

# API Keys - Financial Services
WISE_API_KEY=your_wise_api_key_here

# Blockchain Configuration
STELLAR_SECRET_KEY=your_stellar_testnet_secret_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_app_password
FROM_EMAIL=your_email@example.com

# API Keys - Market Research (new)
FRED_API_KEY=your_fred_api_key_here         # https://fred.stlouisfed.org/docs/api/api_key.html (free)
TAVILY_API_KEY=your_tavily_api_key_here     # https://tavily.com (free tier available)
NEWS_API_KEY=your_news_api_key_here         # https://newsapi.org (free tier available, optional)
